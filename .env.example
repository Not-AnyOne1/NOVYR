# ─────────────────────────────────────────────────────────────
# NOVYR — Environment Variables
# Copy this file to `.env` (local) and set the same values in
# Vercel → Project → Settings → Environment Variables (production).
# ─────────────────────────────────────────────────────────────

# ── Database (PostgreSQL) ──
# Local: postgresql://USER:PASSWORD@localhost:5432/novyr?schema=public
# Neon (recommended for prod): use the POOLED connection string for DATABASE_URL
# and the DIRECT connection string for DIRECT_URL (used by migrations).
DATABASE_URL="postgresql://user:password@localhost:5432/Novyr?schema=public"
DIRECT_URL="postgresql://user:password@localhost:5432/Novyr?schema=public"

# ── Auth.js (NextAuth v5) ──
# Generate a strong secret: `openssl rand -base64 32`
AUTH_SECRET="replace-with-a-32-byte-random-secret"
# Public site URL (no trailing slash). In Vercel this is set automatically,
# but set it explicitly for OAuth callbacks to work in all environments.
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# ── Google OAuth ──
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ── Public site config ──
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_SITE_NAME="NOVYR"

# ── Admin bootstrap ──
# The seed script promotes this email to ADMIN. Use your real admin email.
ADMIN_EMAIL="admin@novyr.com"
ADMIN_PASSWORD="ChangeMe!2026"

# ── Analytics (optional — leave blank to disable) ──
NEXT_PUBLIC_GA_MEASUREMENT_ID=""        # e.g. G-XXXXXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=""            # e.g. 1234567890

# ── Email (optional — newsletter / order confirmations) ──
# If unset, the newsletter stores subscribers in DB only (no provider call).
RESEND_API_KEY=""
EMAIL_FROM="NOVYR <noreply@novyr.com>"

# ── Image storage (optional — Cloudinary unsigned upload) ──
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=""
